[Unit]
Description=Crypto Trading Agent
Documentation=file:/opt/crypto-trading-agent/docs/ARCHITECTURE.md
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/opt/crypto-trading-agent
# Pull latest tagged image and start the stack. Image tag set via .env.
ExecStartPre=/usr/bin/docker compose pull
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
# Rate-limited restart to avoid burning through the exchange API on
# repeated failures.
Restart=on-failure
RestartSec=30
StartLimitBurst=5
StartLimitIntervalSec=300
# Standard hardening.
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/crypto-trading-agent
PrivateTmp=true

[Install]
WantedBy=multi-user.target

# Binance — testnet by default. Generate keys at:
#   spot:    https://testnet.binance.vision/
#   futures: https://testnet.binancefuture.com/
BINANCE_TESTNET=true
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Telegram (create bot via @BotFather; get your user id by messaging the bot
# and visiting https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# News / sentiment (all optional; agent degrades gracefully without them)
CRYPTOPANIC_TOKEN=
WHALE_ALERT_API_KEY=
PERPLEXITY_API_KEY=

# Trading scope
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
TIMEFRAMES=1m,5m,15m,1h
MARKET_TYPE=both  # spot | perps | both

# Risk
ACCOUNT_EQUITY_USD=1000        # used for sizing in paper mode
RISK_PER_TRADE_PCT=0.5         # 0.5% of equity at stop
MAX_NOTIONAL_USD=200           # absolute cap per single trade
MAX_DAILY_LOSS_PCT=3.0
MAX_CONCURRENT_POSITIONS=3
MAX_LEVERAGE=3
MIN_GAP_BETWEEN_TRADES_SEC=300

# Approval flow
AUTO_APPROVE_MAX_NOTIONAL_USD=50   # below this, auto-execute
TWOFA_THRESHOLD_NOTIONAL_USD=500   # above this, require code
APPROVAL_TIMEOUT_SEC=300

# Paper-mode fill realism (BPS = 0.01%)
PAPER_STOP_SLIPPAGE_BPS=25
PAPER_TP_SLIPPAGE_BPS=5

# Total BTC-beta-weighted exposure cap (% of equity)
MAX_CORRELATED_EXPOSURE_PCT=40

# Funding-rate harvesting (delta-neutral): the actual edge in this codebase
FUNDING_HARVEST_ENABLED=true
FUNDING_ENTRY_THRESHOLD_BPS=10
FUNDING_ENTRY_AVG_THRESHOLD_BPS=5
FUNDING_EXIT_THRESHOLD_BPS=2
FUNDING_NOTIONAL_PER_PAIR_USD=100
FUNDING_MAX_CONCURRENT_PAIRS=2

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# Logging
LOG_LEVEL=INFO
